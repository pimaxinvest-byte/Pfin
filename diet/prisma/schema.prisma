generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Sex {
  M
  F
}

enum MealType {
  breakfast
  lunch
  dinner
  snack
}

enum ActivityLevel {
  sedentary
  light
  moderate
  active
  very_active
}

enum DietGoal {
  lose
  maintain
  gain
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile  UserProfile?
  goals    UserGoals?
  diaryEntries    DiaryEntry[]
  nutritionPlan   NutritionPlan?
  weeklyCheckins  WeeklyCheckin[]
  assessments     BodyAssessment[]

  @@map("users")
}

model UserProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  sex           Sex?
  weightKg      Float?
  heightCm      Float?
  birthYear     Int?
  activityLevel ActivityLevel @default(moderate)
  goal          DietGoal      @default(maintain)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserGoals {
  id        String   @id @default(cuid())
  userId    String   @unique
  kcal      Int      @default(2000)
  proteinG  Float    @default(150)
  carbsG    Float    @default(250)
  fatG      Float    @default(67)
  fiberG    Float    @default(30)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_goals")
}

model Food {
  id          String  @id @default(cuid())
  name        String
  brand       String?
  kcalPer100g Float
  proteinG    Float
  carbsG      Float
  fatG        Float
  fiberG      Float   @default(0)
  servingG    Float   @default(100)
  unit        String  @default("g")
  verified    Boolean @default(false)
  createdAt   DateTime @default(now())

  entries DiaryEntry[]

  @@index([name])
  @@map("foods")
}

model DiaryEntry {
  id        String   @id @default(cuid())
  userId    String
  foodId    String
  date      String
  mealType  MealType
  quantityG Float
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id])

  @@index([userId, date])
  @@map("diary_entries")
}

model NutritionPlan {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Step 1 – Current patterns
  mealsPerDay     Int?
  cookingFreq     String?
  eatingOut       String?
  snackPattern    String?
  hydrationLiters Float?
  problemAreas    String?
  restrictions    String?

  // Step 2 – Goals
  primaryGoal     String?
  secondaryGoal   String?
  timelineWeeks   Int?
  previousAttempt String?

  // Step 3 – Approach
  approach        String  @default("calorie_counting")
  kcalMin         Int?
  kcalMax         Int?

  // Step 5 – Obstacles
  restaurantStrategy  String?
  alcoholRule         String?
  travelStrategy      String?
  lowWillpowerMeal    String?
  cravingStrategy     String?

  // Step 6 – Shopping
  shoppingDay   String?
  prepDay       String?

  // Step 7 – Habits (current week index 0-3)
  currentWeek   Int     @default(0)
  week1Habit    String?
  week2Habit    String?
  week3Habit    String?
  week4Habit    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nutrition_plans")
}

model WeeklyCheckin {
  id        String   @id @default(cuid())
  userId    String
  weekDate  String
  energy    Int?
  hunger    Int?
  adherence Int?
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekDate])
  @@map("weekly_checkins")
}

model BodyAssessment {
  id        String   @id @default(cuid())
  userId    String
  date      String

  weightKg  Float?

  // Pliegues cutáneos (mm) — protocolo ISAK
  tricepsMm   Float?   // tricipital
  subscapMm   Float?   // subescapular
  abdomMm     Float?   // abdominal
  suprailMm   Float?   // supraespinal (suprailíaco)
  thighMm     Float?   // muslo

  // Perímetros (cm)
  waistCm    Float?   // abdominal (ombligo)
  hipCm      Float?   // cadera
  neckCm     Float?   // cuello
  armCm      Float?   // brazo (bíceps contraído)
  calfCm     Float?   // pantorrilla

  // Resultados calculados
  bodyFatPct  Float?   // % grasa (Yuhász)
  bodyFatJP   Float?   // % grasa (J&P 3 sitios)
  bodyFatNavy Float?   // % grasa (perímetros US Navy)
  fatMassKg   Float?
  leanMassKg  Float?
  bmr         Int?
  tdee        Int?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
  @@map("body_assessments")
}
